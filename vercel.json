{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/galaxy",  "destination": "/galaxy.html" },
    { "source": "/check",   "destination": "/holonize.html" },
    { "source": "/import",  "destination": "/import.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
